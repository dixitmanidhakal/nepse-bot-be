# Application Settings
APP_NAME=NEPSE Trading Bot
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=True

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Database Configuration
# PostgreSQL connection string format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://your_username:your_password@localhost:5432/nepse_bot

# Alternative individual database settings (if not using DATABASE_URL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nepse_bot
DB_USER=your_username
DB_PASSWORD=your_password

# NEPSE API Configuration
# Base URL for NEPSE API (can be changed to use different API provider)
NEPSE_API_BASE_URL=https://www.nepalstock.com.np/api
NEPSE_API_TIMEOUT=30
NEPSE_API_RETRY_ATTEMPTS=3

# Alternative API Configuration (for future flexibility)
# ALTERNATIVE_API_BASE_URL=https://alternative-api.com/api
# ALTERNATIVE_API_KEY=your_api_key_here

# Trading Configuration
DEFAULT_RISK_PERCENTAGE=1.0
MAX_RISK_PERCENTAGE=2.0
DEFAULT_REWARD_RISK_RATIO=2.0

# Scheduler Configuration
ENABLE_SCHEDULER=True
MARKET_DATA_FETCH_INTERVAL=5      # minutes
SECTOR_ANALYSIS_INTERVAL=15       # minutes
STOCK_SCREENING_INTERVAL=15       # minutes
PATTERN_DETECTION_INTERVAL=15     # minutes
MARKET_DEPTH_INTERVAL=1           # minutes
FLOORSHEET_ANALYSIS_INTERVAL=5    # minutes
SIGNAL_GENERATION_INTERVAL=15     # minutes

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/nepse_bot.log

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# Security (for future use)
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
